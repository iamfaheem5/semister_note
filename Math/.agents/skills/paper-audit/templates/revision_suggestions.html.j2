<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{{ title_text }} — {{ result.file_path }}</title>
<style>
  :root {
    --bg: #ffffff;
    --fg: #1f2329;
    --muted: #5f6675;
    --border: #e1e4ea;
    --accent: #2f5fef;
    --major: #c0392b;
    --moderate: #d97706;
    --minor: #6b7280;
    --code-bg: #f4f5f8;
    --original-bg: #fff8e1;
    --suggested-bg: #ecfdf5;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--fg);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
      "Hiragino Sans", "Microsoft YaHei", Roboto, sans-serif;
    line-height: 1.6;
    font-size: 15px;
  }
  .layout {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
    min-height: 100vh;
  }
  nav.toc {
    background: #f8f9fb;
    border-right: 1px solid var(--border);
    padding: 24px 16px;
    position: sticky;
    top: 0;
    align-self: start;
    max-height: 100vh;
    overflow-y: auto;
  }
  nav.toc h2 {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin: 0 0 12px;
  }
  nav.toc ul { list-style: none; padding: 0; margin: 0; }
  nav.toc li { margin: 6px 0; }
  nav.toc a { color: var(--fg); text-decoration: none; font-size: 13.5px; }
  nav.toc a:hover { color: var(--accent); }
  main {
    padding: 36px 48px 80px;
    max-width: 1080px;
    width: 100%;
  }
  h1 { font-size: 26px; margin: 0 0 4px; line-height: 1.3; }
  .meta-bar {
    border: 1px solid var(--border);
    background: #fafbfc;
    padding: 12px 16px;
    border-radius: 6px;
    color: var(--muted);
    font-size: 13.5px;
    margin: 16px 0 24px;
  }
  .meta-bar code {
    color: var(--fg);
    background: var(--code-bg);
    padding: 1px 6px;
    border-radius: 3px;
    font-size: 12.5px;
  }
  h2 {
    font-size: 19px;
    margin: 32px 0 12px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border);
  }
  h3 { font-size: 16px; margin: 22px 0 8px; }
  h4 {
    font-size: 14px;
    margin: 14px 0 6px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  blockquote {
    margin: 8px 0;
    padding: 8px 14px;
    background: #f7f8fa;
    border-left: 3px solid var(--accent);
    color: var(--fg);
  }
  code {
    background: var(--code-bg);
    padding: 1px 5px;
    border-radius: 3px;
    font-family: "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 13px;
  }
  .suggestion {
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 16px 18px;
    margin: 14px 0;
  }
  .suggestion-header {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 6px;
  }
  .suggestion-header h3 { margin: 0; }
  .meta-line {
    color: var(--muted);
    font-size: 13px;
    margin-bottom: 12px;
  }
  .severity-tag {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 3px;
    color: #fff;
    font-size: 11.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .severity-major { background: var(--major); }
  .severity-moderate { background: var(--moderate); }
  .severity-minor { background: var(--minor); }
  .text-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin: 10px 0;
  }
  .text-block {
    border-radius: 6px;
    padding: 10px 14px;
    font-size: 14px;
  }
  .text-block.original {
    background: var(--original-bg);
    border-left: 3px solid var(--moderate);
  }
  .text-block.suggested {
    background: var(--suggested-bg);
    border-left: 3px solid #10b981;
  }
  .text-block h4 { margin: 0 0 6px; color: var(--fg); }
  .rationale {
    background: #f7f8fa;
    border-left: 3px solid var(--accent);
    padding: 8px 12px;
    margin: 10px 0;
    font-size: 14px;
  }
  ul.actions { padding-left: 22px; }
  ul.actions li { margin: 4px 0; }
  .roadmap ul { list-style: none; padding-left: 0; }
  .roadmap li {
    padding: 6px 0;
    border-bottom: 1px dashed var(--border);
  }
  .roadmap li::before {
    content: "▢ ";
    color: var(--muted);
    margin-right: 6px;
  }
  .anchor-link {
    color: var(--muted);
    text-decoration: none;
    margin-left: 6px;
    font-size: 13px;
  }
  .anchor-link:hover { color: var(--accent); }
  footer {
    border-top: 1px solid var(--border);
    margin-top: 48px;
    padding-top: 16px;
    color: var(--muted);
    font-size: 12.5px;
  }
  @media (max-width: 820px) {
    .layout { grid-template-columns: 1fr; }
    nav.toc { position: static; max-height: none; border-right: none; border-bottom: 1px solid var(--border); }
    main { padding: 24px; }
    .text-pair { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>
<div class="layout">
  <nav class="toc">
    <h2>{{ toc_label }}</h2>
    <ul>
      {% for entry in toc_entries %}
      <li><a href="#{{ entry.anchor }}">{{ entry.label }}</a></li>
      {% endfor %}
    </ul>
  </nav>
  <main>
    <h1>{{ title_text }}</h1>
    <div class="meta-bar">
      <div>
        {{ t('common.paper') | striptags_md }}: <code>{{ result.file_path }}</code>
        &nbsp;|&nbsp; {{ t('common.language') | striptags_md }}: {{ result.language | upper }}
        &nbsp;|&nbsp; {{ t('common.mode') | striptags_md }}: {{ result.mode or 'deep-review' }}
      </div>
      <div>
        {{ t('common.generated') | striptags_md }}: {{ generated_at }}
        {% if result.venue %} &nbsp;|&nbsp; {{ t('common.venue') | striptags_md }}: {{ result.venue }}{% endif %}
      </div>
    </div>

    <p>{{ opening_text }}</p>

    {% if roadmap_buckets %}
    <section id="revision-roadmap" class="roadmap">
      <h2>{{ t('section.revision_roadmap') | replace('## ', '') }}<a class="anchor-link" href="#revision-roadmap">§</a></h2>
      {% for bucket in roadmap_buckets %}
      <h3>{{ bucket.heading }}</h3>
      <ul>
        {% for item in bucket.tasks %}
        <li>{{ item.title }} <code>({{ item.source }}; {{ item.section }})</code></li>
        {% endfor %}
      </ul>
      {% endfor %}
    </section>
    {% endif %}

    {% if suggestions %}
    <section id="detailed-suggestions">
      <h2>{{ t('section.suggestions_breakdown') | replace('## ', '') }}<a class="anchor-link" href="#detailed-suggestions">§</a></h2>
      {% for entry in suggestions %}
      <article class="suggestion" id="suggestion-{{ entry.issue_id or loop.index }}">
        <div class="suggestion-header">
          <h3>{{ entry.issue_id or '' }}{% if entry.issue_id %}: {% endif %}{{ entry.title or '' }}</h3>
          {% if entry.severity %}
          <span class="severity-tag severity-{{ entry.severity }}">{{ severity_display(entry.severity) }}</span>
          {% endif %}
        </div>
        <div class="meta-line">
          {{ t('label.section') | striptags_md }}: {{ entry.section or t('misc.section_unknown') }}
          {% if entry.root_cause_key %}
            &nbsp;·&nbsp; {{ t('label.root_cause_key') | striptags_md }}: <code>{{ entry.root_cause_key }}</code>
          {% endif %}
        </div>
        {% if entry.original_text or entry.suggested_text %}
        <div class="text-pair">
          {% if entry.original_text %}
          <div class="text-block original">
            <h4>{{ t('suggestions.original_block') }}</h4>
            <div>{{ entry.original_text }}</div>
          </div>
          {% endif %}
          {% if entry.suggested_text %}
          <div class="text-block suggested">
            <h4>{{ t('suggestions.suggested_block') }}</h4>
            <div>{{ entry.suggested_text }}</div>
          </div>
          {% endif %}
        </div>
        {% endif %}
        {% if entry.rationale %}
        <div class="rationale"><strong>{{ t('suggestions.rationale_block') }}:</strong> {{ entry.rationale }}</div>
        {% endif %}
        {% if entry.additional_actions %}
        <h4>{{ t('suggestions.actions_block') }}</h4>
        <ul class="actions">
          {% for action in entry.additional_actions %}
          <li>{{ action }}</li>
          {% endfor %}
        </ul>
        {% endif %}
      </article>
      {% endfor %}
    </section>
    {% elif not roadmap_buckets %}
    <p>{{ t('status.no_revision_suggestions') }}</p>
    {% endif %}

    <footer>
      paper-audit · generated {{ generated_at }}
    </footer>
  </main>
</div>
</body>
</html>
