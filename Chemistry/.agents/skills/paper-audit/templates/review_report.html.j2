<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{{ title_text }} — {{ result.file_path }}</title>
<style>
  :root {
    --bg: #ffffff;
    --fg: #1f2329;
    --muted: #5f6675;
    --border: #e1e4ea;
    --accent: #2f5fef;
    --major: #c0392b;
    --moderate: #d97706;
    --minor: #6b7280;
    --code-bg: #f4f5f8;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--fg);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
      "Hiragino Sans", "Microsoft YaHei", Roboto, sans-serif;
    line-height: 1.6;
    font-size: 15px;
  }
  .layout {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
    min-height: 100vh;
  }
  nav.toc {
    background: #f8f9fb;
    border-right: 1px solid var(--border);
    padding: 24px 16px;
    position: sticky;
    top: 0;
    align-self: start;
    max-height: 100vh;
    overflow-y: auto;
  }
  nav.toc h2 {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin: 0 0 12px;
  }
  nav.toc ul { list-style: none; padding: 0; margin: 0; }
  nav.toc li { margin: 6px 0; }
  nav.toc a {
    color: var(--fg);
    text-decoration: none;
    font-size: 13.5px;
  }
  nav.toc a:hover { color: var(--accent); }
  main {
    padding: 36px 48px 80px;
    max-width: 960px;
    width: 100%;
  }
  h1 {
    font-size: 26px;
    margin: 0 0 4px;
    line-height: 1.3;
  }
  .meta-bar {
    border: 1px solid var(--border);
    background: #fafbfc;
    padding: 12px 16px;
    border-radius: 6px;
    color: var(--muted);
    font-size: 13.5px;
    margin: 16px 0 24px;
  }
  .meta-bar code {
    color: var(--fg);
    background: var(--code-bg);
    padding: 1px 6px;
    border-radius: 3px;
    font-size: 12.5px;
  }
  h2 {
    font-size: 19px;
    margin: 32px 0 12px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border);
  }
  h3 {
    font-size: 16px;
    margin: 22px 0 8px;
  }
  blockquote {
    margin: 8px 0;
    padding: 8px 14px;
    background: #f7f8fa;
    border-left: 3px solid var(--accent);
    color: var(--fg);
  }
  code {
    background: var(--code-bg);
    padding: 1px 5px;
    border-radius: 3px;
    font-family: "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 13px;
  }
  pre {
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 12px;
    overflow-x: auto;
    font-size: 13px;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    margin: 8px 0 16px;
    font-size: 13.5px;
  }
  th, td {
    border: 1px solid var(--border);
    padding: 6px 10px;
    text-align: left;
    vertical-align: top;
  }
  th { background: #f4f5f8; font-weight: 600; }
  .issue {
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 14px 16px;
    margin: 12px 0;
  }
  .issue h3 { margin-top: 0; }
  .issue-meta {
    color: var(--muted);
    font-size: 13px;
    margin-bottom: 8px;
  }
  .severity-tag {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 3px;
    color: #fff;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-right: 6px;
  }
  .severity-major { background: var(--major); }
  .severity-moderate { background: var(--moderate); }
  .severity-minor { background: var(--minor); }
  .issue-quote {
    background: #fdf6e3;
    border-left: 3px solid #d97706;
    padding: 6px 10px;
    font-size: 13.5px;
    margin: 6px 0;
  }
  ul.committee-list { padding-left: 22px; }
  .committee-section {
    border-left: 3px solid var(--accent);
    padding: 8px 14px;
    margin: 12px 0;
    background: #f8f9fb;
  }
  .committee-section h3 { margin: 0 0 6px; }
  .ribbon-bundle {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin: 10px 0;
  }
  .ribbon-bundle .pill {
    background: var(--code-bg);
    color: var(--fg);
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 13px;
    border: 1px solid var(--border);
  }
  .anchor-link {
    color: var(--muted);
    text-decoration: none;
    margin-left: 6px;
    font-size: 13px;
  }
  .anchor-link:hover { color: var(--accent); }
  footer {
    border-top: 1px solid var(--border);
    margin-top: 48px;
    padding-top: 16px;
    color: var(--muted);
    font-size: 12.5px;
  }
  @media (max-width: 820px) {
    .layout { grid-template-columns: 1fr; }
    nav.toc { position: static; max-height: none; border-right: none; border-bottom: 1px solid var(--border); }
    main { padding: 24px; }
  }
</style>
</head>
<body>
<div class="layout">
  <nav class="toc" aria-label="{{ t('section.overall_assessment') | replace('## ', '') }}">
    <h2>{{ toc_label }}</h2>
    <ul>
      {% for entry in toc_entries %}
      <li><a href="#{{ entry.anchor }}">{{ entry.label }}</a></li>
      {% endfor %}
    </ul>
  </nav>
  <main>
    <h1>{{ title_text }}</h1>
    <div class="meta-bar">
      <div>
        {{ t('common.paper') | striptags_md }}: <code>{{ result.file_path }}</code>
        &nbsp;|&nbsp; {{ t('common.language') | striptags_md }}: {{ result.language | upper }}
        &nbsp;|&nbsp; {{ t('common.mode') | striptags_md }}: {{ result.mode }}
      </div>
      <div>
        {{ t('common.generated') | striptags_md }}: {{ generated_at }}
        {% if result.venue %} &nbsp;|&nbsp; {{ t('common.venue') | striptags_md }}: {{ result.venue }}{% endif %}
        {% if result.review_focus and result.review_focus != "full" %}
          &nbsp;|&nbsp; {{ t('common.focus') | striptags_md }}: <code>{{ result.review_focus }}</code>
        {% endif %}
      </div>
      {% if result.artifact_dir %}
      <div>
        {{ t('common.artifacts') | striptags_md }}: <code>{{ result.artifact_dir }}</code>
      </div>
      {% endif %}
    </div>

    <section id="overall-assessment">
      <h2>{{ t('section.overall_assessment') | replace('## ', '') }}<a class="anchor-link" href="#overall-assessment">§</a></h2>
      <p>{{ overall_assessment_text }}</p>
      <div class="ribbon-bundle">
        <span class="pill">{{ t('label.major') | striptags_md }}: {{ issue_counts.major }}</span>
        <span class="pill">{{ t('label.moderate') | striptags_md }}: {{ issue_counts.moderate }}</span>
        <span class="pill">{{ t('label.minor') | striptags_md }}: {{ issue_counts.minor }}</span>
      </div>
    </section>

    {% if committee_sections %}
    <section id="committee">
      <h2>{{ t('section.committee') | replace('## ', '') }}<a class="anchor-link" href="#committee">§</a></h2>
      {% for block in committee_sections %}
      <div class="committee-section">
        <h3>{{ block.heading }}</h3>
        <pre>{{ block.body }}</pre>
      </div>
      {% endfor %}
    </section>
    {% endif %}

    {% if result.summary %}
    <section id="paper-summary">
      <h2>{{ t('section.paper_summary') | replace('## ', '') }}<a class="anchor-link" href="#paper-summary">§</a></h2>
      <pre>{{ result.summary }}</pre>
    </section>
    {% endif %}

    {% for bucket in issue_buckets %}
    {% if bucket.issues %}
    <section id="{{ bucket.anchor }}">
      <h2>{{ bucket.heading }}<a class="anchor-link" href="#{{ bucket.anchor }}">§</a></h2>
      {% for issue in bucket.issues %}
      <article class="issue">
        <h3><span class="severity-tag severity-{{ issue.severity }}">{{ severity_display(issue.severity) }}</span>{{ bucket.prefix }}{{ loop.index }}: {{ issue.title }}</h3>
        <div class="issue-meta">
          {{ t('label.type') | striptags_md }}: {{ issue.comment_type }}
          &nbsp;|&nbsp; {{ t('label.source') | striptags_md }}: {{ source_label(issue) }}
          &nbsp;|&nbsp; {{ t('label.confidence') | striptags_md }}: {{ issue.confidence }}
          &nbsp;|&nbsp; {{ t('label.section') | striptags_md }}: {{ issue.source_section or t('misc.section_unknown') }}
          {% if issue.related_sections %}
            &nbsp;|&nbsp; {{ t('label.related_sections') | striptags_md }}: {{ issue.related_sections | join(', ') }}
          {% endif %}
          {% if issue.quote_verified is not none %}
            &nbsp;|&nbsp; {{ t('label.quote_verified') | striptags_md }}: {{ t('label.yes') if issue.quote_verified else t('label.no') }}
          {% endif %}
        </div>
        {% if issue.quote %}
        <div class="issue-quote">{{ issue.quote }}</div>
        {% endif %}
        <p>{{ issue.explanation }}</p>
      </article>
      {% endfor %}
    </section>
    {% endif %}
    {% endfor %}

    <section id="decision-signals">
      <h2>{{ t('section.decision_signals') | replace('## ', '') }}<a class="anchor-link" href="#decision-signals">§</a></h2>
      <ul>
        {% if committee_score is not none %}<li>{{ t('label.committee_score') | striptags_md }}: {{ "%.1f"|format(committee_score) }}/10</li>{% endif %}
        {% if editor_verdict %}<li>{{ t('label.editor_verdict') | striptags_md }}: {{ editor_verdict }}</li>{% endif %}
        <li>{{ t('label.reviewer_recommendation') | striptags_md }}: {{ recommendation_display }}</li>
        <li>{{ t('label.issue_bundle') | striptags_md }}: {{ issue_bundle_summary }}</li>
      </ul>
    </section>

    <footer>
      paper-audit · generated {{ generated_at }}
    </footer>
  </main>
</div>
</body>
</html>
